---
interface Props {
  variant?: 'light' | 'dark';
}
const { variant = 'light' } = Astro.props;
---

<a href="/" class={`logo logo--${variant}`} aria-label="Sixense — home">
  <svg
    class="logo-mark"
    viewBox="50 15 100 102"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    width="44"
    height="44"
    aria-hidden="true"
  >
    <polygon points="100,18 122,31 122,57 100,70 78,57 78,31" stroke="#F4C542" stroke-width="3" fill="none" stroke-linejoin="round"/>
    <polygon points="126,62 148,75 148,101 126,114 104,101 104,75" stroke="#F4C542" stroke-width="3" fill="none" stroke-linejoin="round"/>
    <polygon points="74,62 96,75 96,101 74,114 52,101 52,75" stroke="#F4C542" stroke-width="3" fill="none" stroke-linejoin="round"/>
    <circle cx="100" cy="88" r="4" fill="#F4C542"/>
    <line x1="100" y1="84" x2="100" y2="70" stroke="#F4C542" stroke-width="1.5"/>
    <line x1="100" y1="88" x2="116" y2="96" stroke="#F4C542" stroke-width="1.5"/>
    <line x1="100" y1="88" x2="84" y2="96" stroke="#F4C542" stroke-width="1.5"/>
  </svg>
  <span class="logo-wordmark">s<span class="logo-i">ı</span>xense</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
    min-width: 160px;
  }
  .logo-mark {
    flex-shrink: 0;
    transform-origin: center;
    transition: transform 500ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .logo:hover .logo-mark {
    transform: rotate(120deg);
  }
  .logo-wordmark {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-weight: 700;
    font-size: 22px;
    letter-spacing: 0.01em;
    line-height: 1;
    color: var(--color-ink);
    white-space: nowrap;
  }
  .logo--dark .logo-wordmark {
    color: var(--color-paper);
  }
  .logo-i {
    position: relative;
    display: inline-block;
  }
  .logo-i::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 0.04em;
    width: 0.22em;
    height: 0.22em;
    background: #F4C542;
    border-radius: 50%;
  }

  @media (max-width: 767px) {
    .logo { min-width: 130px; }
    .logo-wordmark { font-size: 20px; }
    .logo-mark { width: 38px; height: 38px; }
  }
</style>

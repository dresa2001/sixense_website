---
interface Props {
  variant?: 'light' | 'dark';
  width?: number;
}
const { variant = 'light', width = 160 } = Astro.props;
const markColor = variant === 'dark' ? '#F5A623' : '#D4881A';
const textColor = variant === 'dark' ? '#F5F3EE' : '#1A1A18';
---

<a href="/" class="logo" aria-label="Sixense — home" style={`min-width:${width}px; flex-shrink:0`}>
  <svg
    class="logo-mark"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 48 48"
    fill="none"
    width="36"
    height="36"
    aria-hidden="true"
  >
    <polygon points="24,4 31.2,8.4 31.2,17.2 24,21.6 16.8,17.2 16.8,8.4"
      stroke={markColor} stroke-width="2" fill="none" stroke-linejoin="round"/>
    <polygon points="11,21 18.2,25.4 18.2,34.2 11,38.6 3.8,34.2 3.8,25.4"
      stroke={markColor} stroke-width="2" fill="none" stroke-linejoin="round"/>
    <polygon points="37,21 44.2,25.4 44.2,34.2 37,38.6 29.8,34.2 29.8,25.4"
      stroke={markColor} stroke-width="2" fill="none" stroke-linejoin="round"/>
    <line x1="24" y1="29" x2="24" y2="21.6" stroke={markColor} stroke-width="1.5"/>
    <line x1="24" y1="29" x2="18.2" y2="25.4" stroke={markColor} stroke-width="1.5"/>
    <line x1="24" y1="29" x2="29.8" y2="25.4" stroke={markColor} stroke-width="1.5"/>
    <circle cx="24" cy="29" r="2.5" fill={markColor}/>
  </svg>

  <span class="logo-wordmark" style={`color:${textColor}`}>s<span style={`color:${markColor}`}>i</span>xense</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .logo-mark {
    flex-shrink: 0;
    transform-origin: center;
    transition: transform 500ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .logo:hover .logo-mark { transform: rotate(120deg); }
  .logo-wordmark {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    font-weight: 700;
    font-size: 20px;
    letter-spacing: 0.02em;
    line-height: 1;
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Watermark from '../components/Watermark.astro';

const principles = [
  { icon: 'sliders', heading: 'We start with your process, not a template', body: "Every solution is designed around how your business actually works — not a generic workflow or a platform's default settings." },
  { icon: 'puzzle-piece', heading: 'We build in components, not monoliths', body: "Solutions are assembled from small, connected parts. Easier to change, extend and integrate. What we build today doesn't become a ceiling on what you can do tomorrow." },
  { icon: 'wrench', heading: 'We pick the right tool for the job', body: "We're not advocates for any single platform. We select what fits — weighing cost, performance, security and reliability." },
  { icon: 'shield-check', heading: 'We build AI responsibly', body: "Data privacy, security and responsible AI practices are built in from the start. Your data stays yours. AI is introduced where it genuinely adds value." },
];

---

<BaseLayout
  title="How we work — Sixense"
  description="We start with your business, not the technology. Short build cycles, senior people, no handoffs. Here's how we engage and deliver."
>
  <!-- Hero -->
  <section class="hero section-dark" aria-labelledby="hww-heading">
    <Watermark />
    <Watermark secondary={true} />
    <div class="container">
      <span class="section-label">How we work</span>
      <h1 id="hww-heading" class="animate-in" style="color:var(--color-paper);max-width:760px">
        Process first. Experience led. Real solutions.
      </h1>
      <p class="animate-in" data-delay="80ms" style="font-size:20px;color:rgba(245,243,238,0.65);max-width:580px;margin-top:var(--space-3);line-height:1.7">
        We start with your business, not the technology. Then we build quickly and show you something real as fast as possible.
      </p>
    </div>
  </section>

  <!-- Our Approach: label + H2 + image LEFT; body text RIGHT; callouts full-width below -->
  <section class="section" aria-labelledby="approach-heading">
    <Watermark variant="light" side="right" />
    <div class="container">
      <div class="two-col two-col-50-50">
        <div>
          <span class="section-label">Our approach</span>
          <h2 id="approach-heading" class="animate-in">
            We work backwards<br />from the outcome.
          </h2>
          <div class="image-container animate-in" data-delay="80ms">
            <img
              src="/assets/Working_backwards.avif"
              alt="Diagram illustrating working backwards from a defined outcome"
              loading="lazy"
            />
          </div>
        </div>
        <div class="approach-right">
          <p class="animate-in" style="color:var(--color-ink-secondary);font-size:17px;line-height:1.75">
            Every engagement starts with a clear picture of what better looks like for
            your business. From there we work back through your processes, people, systems
            and data to understand what needs to change and what the right path forward looks like.
          </p>
          <p class="animate-in" data-delay="80ms" style="color:var(--color-ink-secondary);font-size:17px;margin-top:1em;line-height:1.75">
            This keeps solutions grounded in how your business actually works from day one.
            And it keeps scope honest — we're building toward a defined outcome,
            not generating work.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- Our Method: text LEFT, image RIGHT with offset -->
  <section class="section section-secondary" aria-labelledby="method-heading">
    <Watermark variant="light" side="left" />
    <div class="container two-col two-col-50-50">
      <div>
        <span class="section-label">Our method</span>
        <h2 id="method-heading" class="animate-in">
          Start small. Prove value. Scale smart.
        </h2>
        <p class="animate-in" data-delay="80ms" style="color:var(--color-ink-secondary);font-size:17px;margin-top:var(--space-3);line-height:1.7">
          We don't disappear for months and return with something finished. We build in
          short cycles, put working solutions in your hands quickly and improve from
          there. Every increment delivers something usable. Every milestone is a
          decision point — you stay in control of pace and investment throughout.
        </p>
        <p class="animate-in" data-delay="120ms" style="color:var(--color-ink-secondary);font-size:17px;margin-top:1em;line-height:1.7">
          This approach gets value into your hands fast. It surfaces the things that are hard to
          specify on paper but obvious the moment you can see something real. And it
          means everything we build can be extended and scaled without starting again.
        </p>
      </div>
      <div class="image-container-offset animate-in" data-delay="80ms">
        <img
          src="/assets/Start-small-prove-value-scale-smart.avif"
          alt="Diagram illustrating the approach: start small, prove value, scale smart"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- How We Build — light background (not secondary, to separate from Our Method) -->
  <section class="section" aria-labelledby="build-heading">
    <Watermark variant="light" side="right" />
    <div class="container">
      <span class="section-label" style="justify-content:center">Our principles</span>
      <h2 id="build-heading" class="animate-in" style="text-align:center;margin-bottom:var(--space-5)">
        How we build
      </h2>
      <div class="principles-grid">
        {principles.map((p, i) => (
          <div class="principle animate-in" data-delay={`${i * 80}ms`}>
            <i class={`ph ph-${p.icon}`} style="font-size:28px;color:#F4C542;" aria-hidden="true"></i>
            <h3 class="principle-heading">{p.heading}</h3>
            <p class="principle-body">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who You'll Work With -->
  <section class="section section-secondary" aria-labelledby="team-heading">
    <Watermark variant="light" side="left" />
    <div class="container two-col two-col-40-55">
      <div>
        <span class="section-label">Our team</span>
        <h2 id="team-heading" class="animate-in">
          Senior people.<br />Direct access.<br />No handoffs.
        </h2>
      </div>
      <div>
        <p class="animate-in" style="color:var(--color-ink-secondary);font-size:17px;line-height:1.75">
          You deal with the same people throughout — the ones who scoped the work and
          are accountable for the outcome. No account managers. No handoffs once the
          contract is signed. We communicate plainly, flag problems early and don't
          generate unnecessary complexity.
        </p>
        <p class="animate-in" data-delay="80ms" style="color:var(--color-ink-secondary);font-size:17px;margin-top:1em;line-height:1.75">
          We're not here to make ourselves indispensable. We're here to build something
          that works, prove it quickly and earn the right to do more.
        </p>
        <p class="pull-quote animate-in" data-delay="120ms">
          The quality and accountability of a senior local firm, at a price point
          that makes sense for a mid-sized business.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-dark hww-cta" aria-labelledby="hww-cta-heading">
    <Watermark />
    <Watermark secondary={true} />
    <div class="container cta-inner">
      <span class="section-label" style="justify-content:center">Work with us</span>
      <h2 id="hww-cta-heading" class="animate-in">Does this sound like your business?</h2>
      <p class="animate-in" data-delay="80ms">
        Start with a free Fit Call. Thirty minutes, no pitch — just an honest conversation
        about whether there's something worth building.
      </p>
      <a href="/contact" class="btn btn-primary animate-in" data-delay="160ms">Book a free Fit Call →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { padding-top: 120px; padding-bottom: 80px; }

  /* Our Approach — image in left col below heading */
  .image-container {
    background: var(--color-paper-secondary);
    border-radius: var(--radius-xl);
    padding: 32px;
    overflow: hidden;
    align-self: flex-start;
    margin-top: var(--space-3);
  }

  /* Right column: offset body text to align with top of image */
  .approach-right {
    padding-top: 100px; /* approx: section-label + H2 + margin */
  }

  /* Our Method — image offset to align with body text start */
  .image-container-offset {
    background: var(--color-paper);
    border-radius: var(--radius-xl);
    padding: 32px;
    overflow: hidden;
    align-self: flex-start;
    margin-top: 100px; /* approx: section-label + H2 + 20px gap */
  }

  .pull-quote {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    color: var(--color-ink);
    border-left: 3px solid var(--color-accent);
    padding-left: 24px;
    margin-top: var(--space-4);
  }

  .principles-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }

  .hww-cta {
    text-align: center;
    padding-block: var(--space-7);
  }
  .cta-inner {
    max-width: 600px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }
  .cta-inner h2 {
    color: var(--color-paper);
    font-size: var(--text-h2);
  }
  .cta-inner p {
    color: rgba(245, 243, 238, 0.65);
    font-size: 18px;
    line-height: 1.7;
    margin: 0;
  }
  .cta-inner .btn { margin-top: var(--space-2); }

  @media (max-width: 767px) {
    .hero { padding-top: 112px; }
    .principles-grid { grid-template-columns: 1fr; }
    .callout-grid { grid-template-columns: 1fr; }
    .approach-right { padding-top: 0; }
    .image-container-offset { margin-top: var(--space-3); }
  }
</style>

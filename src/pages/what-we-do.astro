---
import BaseLayout from '../layouts/BaseLayout.astro';
import ClosingCTA from '../components/ClosingCTA.astro';
import Watermark from '../components/Watermark.astro';

const serviceCards = [
  { icon: 'receipt', heading: 'Finance & accounts', body: 'Invoice matching and approval workflows. Automated reconciliation. Payment follow-up and dunning. Month-end reporting without the scramble.' },
  { icon: 'clipboard-text', heading: 'Procurement & supplier management', body: 'Purchase order automation. Supplier onboarding and credential tracking. Contract expiry alerts. Spend visibility across fragmented systems.' },
  { icon: 'map-pin', heading: 'Field service & scheduling', body: 'Live job visibility and dispatch optimisation. Automated scheduling based on location, skills and availability. Real-time status updates without the phone calls.' },
  { icon: 'file-text', heading: 'Document processing', body: 'Automated document classification and data extraction. Contract review and flagging. Forms processing without manual rekeying.' },
  { icon: 'package', heading: 'Warehouse & inventory', body: 'Live inventory visibility across locations. Automated reorder triggers. Inbound and outbound reconciliation. Order status without chasing the warehouse.' },
  { icon: 'chart-line-up', heading: 'Sales operations', body: "Live product, pricing and inventory access for field reps. Order submission without back-office delays. Pipeline reporting without a spreadsheet." },
  { icon: 'headset', heading: 'Contact centre & service desk', body: 'Intelligent triage and routing. Automated responses to common requests. Knowledge assistants that give agents the right answer faster.' },
  { icon: 'chart-bar', heading: 'Reporting & business intelligence', body: 'Automated data pipelines from fragmented sources. Dashboards that update without someone building them each week. Alerts when something needs attention.' },
  { icon: 'wrench', heading: 'Asset operations', body: 'Failure prediction and maintenance optimisation. Work order scheduling automation. Language-first work execution via voice or text. Document intelligence for maintenance records and compliance.' },
];

const approachCards = [
  {
    icon: 'git-branch',
    label: 'Rule-based',
    heading: 'Task & rule automation',
    body: 'Handles repeatable logic — consistent, fast and predictable. The right foundation for any process that follows defined steps every time.',
  },
  {
    icon: 'chart-line',
    label: 'Decision support & insights',
    heading: 'Data analysis & recommendations',
    body: 'Analyses data from across your systems and surfaces clear recommendations for your team to act on. Turns information overload into decision clarity.',
  },
  {
    icon: 'sparkle',
    label: 'AI',
    heading: 'Agents and bots',
    body: 'Understands and generates language, documents, images, audio and other unstructured data. Handles the interactions and processing that used to require a person.',
  },
  {
    icon: 'robot',
    label: 'Autonomous',
    heading: 'Agentic systems',
    body: "Goal-oriented AI that monitors, decides and acts across complex workflows — with human oversight built in. Not science fiction. We're building and delivering this now.",
  },
];

const buildTiers = [
  { label: 'Tier 1', heading: 'Task & workflow automation', body: 'Targeted automation of specific manual tasks, handoffs and data flows. Fast to deliver, immediate in impact.' },
  { label: 'Tier 2', heading: 'Process & integrated automation', body: 'Connecting the dots across systems, teams and functions. Eliminates coordination overhead and gives management real visibility.' },
  { label: 'Tier 3', heading: 'Agentic automation', body: "Goal-oriented AI that monitors, decides and acts across complex workflows — with human oversight built in. Not science fiction. We're building this now." },
];
---

<BaseLayout
  title="What we do — Sixense"
  description="We design and build automation and AI solutions across finance, field service, procurement, document processing and more. Fixed scope. Real outcomes."
>
  <!-- Hero -->
  <section class="hero section-dark" aria-labelledby="wwd-heading">
    <Watermark />
    <Watermark secondary={true} />
    <div class="container">
      <span class="section-label">What we do</span>
      <h1 id="wwd-heading" class="animate-in" style="max-width:720px;color:var(--color-paper)">
        Fix what's broken. Build what's missing.
      </h1>
      <p class="hero-sub animate-in" data-delay="80ms">
        Some of the businesses we work with have a specific problem they need fixed.
        Others can see an opportunity — a new capability, a better way of operating,
        something a competitor is doing that they can't yet — but have no way to build
        toward it. We do both.
      </p>
      <p class="hero-sub animate-in" data-delay="120ms" style="margin-top:1em">
        We design and build automation and AI solutions that eliminate operational drag
        and unlock capabilities that were previously out of reach. Each solution is built
        to stand alone and connect forward — so what we build today becomes the
        foundation for something more powerful tomorrow.
      </p>
    </div>
  </section>

  <!-- Outcomes We Enable -->
  <section class="section" aria-labelledby="service-heading">
    <Watermark variant="light" side="right" />
    <div class="container">
      <span class="section-label">Outcomes we enable</span>
      <h2 id="service-heading" class="animate-in">
        If your team is doing any of the following manually,<br />there's likely a better way.
      </h2>
      <div class="service-grid">
        {serviceCards.map((card, i) => (
          <div class="service-card animate-in" data-delay={`${(i % 3) * 80}ms`}>
            <div class="icon-circle icon-circle-sm">
              <i class={`ph ph-${card.icon}`} style="font-size:32px;color:#00C2FF;" aria-hidden="true"></i>
            </div>
            <h3 class="svc-heading">{card.heading}</h3>
            <p class="svc-body">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Not All Automation Is the Same — 4-col card layout -->
  <section class="section section-secondary" aria-labelledby="approach-heading">
    <Watermark variant="light" side="left" />
    <div class="container">
      <div class="approach-header animate-in">
        <span class="section-label" style="justify-content:center">The approach</span>
        <h2 id="approach-heading" style="text-align:center">
          Not all automation is the same.
        </h2>
      </div>
      <div class="approach-cards">
        {approachCards.map((card, i) => (
          <div class="approach-card animate-in" data-delay={`${i * 80}ms`}>
            <div class="icon-circle icon-circle-md" style="margin-bottom:var(--space-3)">
              <i class={`ph ph-${card.icon}`} style="font-size:36px;color:#00C2FF;" aria-hidden="true"></i>
            </div>
            <span class="approach-label">{card.label}</span>
            <h3 class="approach-card-heading">{card.heading}</h3>
            <p class="approach-card-body">{card.body}</p>
          </div>
        ))}
      </div>
      <p class="approach-footer animate-in">
        We match the right approach to the right problem.
        Often a single solution draws on more than one.
      </p>
    </div>
  </section>

  <!-- How We Engage -->
  <section class="section" aria-labelledby="engage-heading">
    <Watermark variant="light" side="right" />
    <div class="container">
      <span class="section-label">How we engage</span>
      <h2 id="engage-heading" class="animate-in" style="max-width:560px">
        Every engagement starts small and builds with purpose.
        Nothing is open-ended.
      </h2>
      <div class="engage-panels">
        <div class="engage-panel animate-in">
          <div class="icon-circle icon-circle-lg">
            <i class="ph ph-phone" style="font-size:48px;color:#00C2FF;" aria-hidden="true"></i>
          </div>
          <span class="engage-tag">Free · 30 minutes</span>
          <h3 class="engage-heading">The Fit Call</h3>
          <p class="engage-body">
            An honest conversation to find out if there's a real problem and whether we're
            the right fit. No pitch. If there's something worth solving, we'll say so.
            If there isn't, we'll say that too.
          </p>
          <a href="/contact" class="btn btn-ghost">Book a Fit Call →</a>
        </div>
        <div class="engage-panel animate-in" data-delay="80ms">
          <div class="icon-circle icon-circle-lg">
            <i class="ph ph-magnifying-glass" style="font-size:48px;color:#00C2FF;" aria-hidden="true"></i>
          </div>
          <span class="engage-tag">Fixed time · Fixed price</span>
          <h3 class="engage-heading">The Discovery Sprint</h3>
          <p class="engage-body">
            A structured working session requiring up to four hours of your time across five
            days. We map your most pressing processes, assess where automation can make the
            biggest difference and hand you a clear, plain-English report. Most clients find
            the clarity alone is worth the fee.
          </p>
          <a href="/how-we-work" class="btn btn-ghost">Learn more →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- How We Build -->
  <section class="section section-secondary" aria-labelledby="build-heading">
    <Watermark variant="light" side="left" />
    <div class="container">
      <span class="section-label">How we build</span>
      <h2 id="build-heading" class="animate-in" style="max-width:520px">
        From targeted fixes to autonomous workflows.
      </h2>
      <div class="build-tiers animate-in" data-delay="80ms">
        {buildTiers.map(tier => (
          <div class="build-tier">
            <span class="card-label">{tier.label}</span>
            <p class="build-heading">{tier.heading}</p>
            <p class="build-body">{tier.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The Growth Program -->
  <section class="section" aria-labelledby="growth-heading" style="padding-block:var(--space-6)">
    <Watermark variant="light" side="right" />
    <div class="container two-col" style="grid-template-columns:30% 65%">
      <div>
        <span class="section-label">Ongoing engagement</span>
      </div>
      <div>
        <h3 id="growth-heading" class="animate-in">The Growth Program</h3>
        <p class="animate-in" data-delay="80ms" style="font-size:17px;color:var(--color-ink-secondary);margin-top:var(--space-2);line-height:1.7">
          Once we've delivered something together and you know how we work, we can stay
          engaged — continuously improving what's been built and finding the next
          opportunity. This isn't something we lead with. It's something clients ask for.
        </p>
      </div>
    </div>
  </section>

  <ClosingCTA
    heading="Not sure where you sit?"
    body="Start with the Fit Call. It's free and it'll be obvious pretty quickly."
    ctaLabel="Book a free Fit Call →"
    showContactLink={false}
  />
</BaseLayout>

<style>
  .hero { padding-top: 120px; padding-bottom: 80px; }
  .hero-sub {
    font-size: 18px;
    line-height: 1.7;
    color: rgba(245, 243, 238, 0.65);
    max-width: 620px;
    margin-top: var(--space-3);
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: var(--space-5);
  }
  .svc-heading {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    color: var(--color-ink);
  }
  .svc-body { font-size: 14px; color: var(--color-ink-secondary); line-height: 1.6; margin: 0; }

  /* Approach — 4-col card layout */
  .approach-header {
    text-align: center;
    margin-bottom: var(--space-5);
  }
  .approach-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
  }
  .approach-card {
    background: var(--color-paper);
    border-radius: var(--radius-lg);
    padding: 28px 24px;
    border-top: 3px solid var(--color-accent);
    display: flex;
    flex-direction: column;
  }
  .approach-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 11px;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }
  .approach-card-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    color: var(--color-ink);
    line-height: 1.3;
    margin-bottom: 12px;
  }
  .approach-card-body {
    font-size: 14px;
    color: var(--color-ink-secondary);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }
  .approach-footer {
    text-align: center;
    font-size: 16px;
    color: var(--color-ink-secondary);
    max-width: 560px;
    margin: var(--space-5) auto 0;
  }

  .engage-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-5);
  }
  .engage-panel {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .engage-tag {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 11px;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-sm);
    padding: 4px 10px;
    display: inline-block;
    width: fit-content;
  }
  .engage-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    color: var(--color-ink);
  }
  .engage-body { font-size: 15px; color: var(--color-ink-secondary); line-height: 1.6; flex: 1; margin: 0; }

  .build-tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }
  .build-tier {
    padding: var(--space-4);
    border-right: 1px solid var(--color-border);
  }
  .build-tier:last-child { border-right: none; }
  .build-heading {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    color: var(--color-ink);
    margin-bottom: 12px;
  }
  .build-body { font-size: 14px; color: var(--color-ink-secondary); line-height: 1.6; margin: 0; }

  @media (max-width: 1279px) {
    .service-grid { grid-template-columns: repeat(2, 1fr); }
    .approach-cards { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 767px) {
    .hero { padding-top: 112px; }
    .hero-sub { font-size: 16px; }
    .service-grid { grid-template-columns: 1fr; }
    .approach-cards { grid-template-columns: 1fr; }
    .engage-panels { grid-template-columns: 1fr; }
    .build-tiers { grid-template-columns: 1fr; }
    .build-tier { border-right: none; border-bottom: 1px solid var(--color-border); }
    .build-tier:last-child { border-bottom: none; }
  }
</style>

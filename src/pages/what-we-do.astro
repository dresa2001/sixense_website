---
import BaseLayout from '../layouts/BaseLayout.astro';
import ClosingCTA from '../components/ClosingCTA.astro';
import Watermark from '../components/Watermark.astro';

const serviceCards = [
  { icon: 'receipt', heading: 'Finance & accounts', body: 'Invoice matching and approval workflows. Automated reconciliation. Payment follow-up and dunning. Month-end reporting without the scramble.' },
  { icon: 'clipboard-text', heading: 'Procurement & supplier management', body: 'Purchase order automation. Supplier onboarding and credential tracking. Contract expiry alerts. Spend visibility across fragmented systems.' },
  { icon: 'map-pin', heading: 'Field service & scheduling', body: 'Live job visibility and dispatch optimisation. Automated scheduling based on location, skills and availability. Real-time status updates without the phone calls.' },
  { icon: 'file-text', heading: 'Document processing', body: 'Automated document classification and data extraction. Contract review and flagging. Forms processing without manual rekeying.' },
  { icon: 'package', heading: 'Warehouse & inventory', body: 'Live inventory visibility across locations. Automated reorder triggers. Inbound and outbound reconciliation. Order status without chasing the warehouse.' },
  { icon: 'chart-line-up', heading: 'Sales operations', body: "Live product, pricing and inventory access for field reps. Order submission without back-office delays. Pipeline reporting without a spreadsheet." },
  { icon: 'headset', heading: 'Contact centre & service desk', body: 'Intelligent triage and routing. Automated responses to common requests. Knowledge assistants that give agents the right answer faster.' },
  { icon: 'chart-bar', heading: 'Reporting & business intelligence', body: 'Automated data pipelines from fragmented sources. Dashboards that update without someone building them each week. Alerts when something needs attention.' },
];

const approachBlocks = [
  { icon: 'git-branch', label: 'Rule-based', heading: 'Task & rule automation', body: 'Handles repeatable logic — consistent, fast, predictable.' },
  { icon: 'brain', label: 'Decision support', heading: 'Data analysis & recommendations', body: 'Analyses data and surfaces recommendations for your team to act on.' },
  { icon: 'sparkle', label: 'Language & context', heading: 'GenAI applications', body: 'Understands language, documents and unstructured data.' },
  { icon: 'robot', label: 'Autonomous', heading: 'Agentic systems', body: 'Acts independently within defined boundaries — with human oversight built in.' },
];

const buildTiers = [
  { label: 'Tier 1', heading: 'Task & workflow automation', body: 'Targeted automation of specific manual tasks, handoffs and data flows. Fast to deliver, immediate in impact.' },
  { label: 'Tier 2', heading: 'Process & integrated automation', body: 'Connecting the dots across systems, teams and functions. Eliminates coordination overhead and gives management real visibility.' },
  { label: 'Tier 3', heading: 'Agentic automation', body: "Goal-oriented AI that monitors, decides and acts across complex workflows — with human oversight built in. Not science fiction. We're building this now." },
];
---

<BaseLayout
  title="What we do — Sixense"
  description="We design and build automation and AI solutions across finance, field service, procurement, document processing and more. Fixed scope. Real outcomes."
>
  <!-- Hero -->
  <section class="hero section-dark" aria-labelledby="wwd-heading">
    <Watermark />
    <div class="container">
      <span class="section-label">What we do</span>
      <h1 id="wwd-heading" class="animate-in" style="max-width:720px;color:var(--color-paper)">
        We fix the operational problems that have been on your list too long.
        And we build the capabilities you haven't been able to reach.
      </h1>
      <p class="hero-sub animate-in" data-delay="80ms">
        Some of the businesses we work with have a specific problem they need fixed.
        Others can see an opportunity — a new capability, a better way of operating,
        something a competitor is doing that they can't yet — but have no way to build
        toward it. We do both.
      </p>
    </div>
  </section>

  <!-- Where We Work -->
  <section class="section" aria-labelledby="service-heading">
    <div class="container">
      <span class="section-label">Where we work</span>
      <h2 id="service-heading" class="animate-in">
        If your team is doing any of the following manually,<br />there's likely a better way.
      </h2>
      <div class="service-grid">
        {serviceCards.map((card, i) => (
          <div class="service-card animate-in" data-delay={`${(i % 3) * 80}ms`}>
            <div class="icon-circle icon-circle-sm">
              <ph-icon name={card.icon} size="32" color="#00C2FF"></ph-icon>
            </div>
            <h3 class="svc-heading">{card.heading}</h3>
            <p class="svc-body">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The Approach -->
  <section class="section section-secondary" aria-labelledby="approach-heading">
    <div class="container two-col" style="grid-template-columns:30% 65%">
      <div>
        <span class="section-label">The approach</span>
        <h2 id="approach-heading" class="animate-in">
          Not all automation<br />is the same.
        </h2>
      </div>
      <div class="animate-in" data-delay="80ms">
        {approachBlocks.map(block => (
          <div class="approach-block">
            <div class="approach-block-header">
              <ph-icon name={block.icon} size="24" color="#00C2FF"></ph-icon>
              <span class="card-label">{block.label}</span>
            </div>
            <p class="approach-heading">{block.heading}</p>
            <p class="approach-body">{block.body}</p>
          </div>
        ))}
        <p style="font-size:16px;color:var(--color-ink-secondary);margin-top:var(--space-3)">
          We match the right approach to the right problem.
          Often a single solution draws on more than one.
        </p>
      </div>
    </div>
  </section>

  <!-- How We Engage -->
  <section class="section" aria-labelledby="engage-heading">
    <div class="container">
      <span class="section-label">How we engage</span>
      <h2 id="engage-heading" class="animate-in" style="max-width:560px">
        Every engagement starts small and builds with purpose.
        Nothing is open-ended.
      </h2>
      <div class="engage-panels">
        <div class="engage-panel animate-in">
          <div class="icon-circle icon-circle-lg">
            <ph-icon name="phone" size="48" color="#00C2FF"></ph-icon>
          </div>
          <span class="engage-tag">Free · 30 minutes</span>
          <h3 class="engage-heading">The Fit Call</h3>
          <p class="engage-body">
            An honest conversation to find out if there's a real problem and whether we're
            the right fit. No pitch. If there's something worth solving, we'll say so.
            If there isn't, we'll say that too.
          </p>
          <a href="/contact" class="btn btn-ghost">Book a Fit Call →</a>
        </div>
        <div class="engage-panel animate-in" data-delay="80ms">
          <div class="icon-circle icon-circle-lg">
            <ph-icon name="magnifying-glass" size="48" color="#00C2FF"></ph-icon>
          </div>
          <span class="engage-tag">Fixed time · Fixed price</span>
          <h3 class="engage-heading">The Discovery Sprint</h3>
          <p class="engage-body">
            A structured working session requiring up to four hours of your time across five
            days. We map your most pressing processes, assess where automation can make the
            biggest difference and hand you a clear, plain-English report. Most clients find
            the clarity alone is worth the fee.
          </p>
          <a href="/how-we-work" class="btn btn-ghost">Learn more →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- How We Build -->
  <section class="section section-secondary" aria-labelledby="build-heading">
    <div class="container">
      <span class="section-label">How we build</span>
      <h2 id="build-heading" class="animate-in" style="max-width:520px">
        From targeted fixes to autonomous workflows.
      </h2>
      <div class="build-tiers animate-in" data-delay="80ms">
        {buildTiers.map(tier => (
          <div class="build-tier">
            <span class="card-label">{tier.label}</span>
            <p class="build-heading">{tier.heading}</p>
            <p class="build-body">{tier.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ClosingCTA />
</BaseLayout>

<style>
  .hero { padding-top: 120px; padding-bottom: 80px; }
  .hero-sub {
    font-size: 18px;
    line-height: 1.7;
    color: rgba(245, 243, 238, 0.65);
    max-width: 620px;
    margin-top: var(--space-3);
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: var(--space-5);
  }
  .svc-heading {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    color: var(--color-ink);
  }
  .svc-body { font-size: 14px; color: var(--color-ink-secondary); line-height: 1.6; margin: 0; }

  .approach-block {
    padding-block: var(--space-3);
    border-top: 1px solid var(--color-border);
  }
  .approach-block:last-of-type { border-bottom: 1px solid var(--color-border); margin-bottom: 0; }
  .approach-block-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
  }
  .approach-heading {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    color: var(--color-ink);
    margin-bottom: 6px;
  }
  .approach-body { font-size: 15px; color: var(--color-ink-secondary); margin: 0; }

  .engage-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-5);
  }
  .engage-panel {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .engage-tag {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 11px;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-sm);
    padding: 4px 10px;
    display: inline-block;
    width: fit-content;
  }
  .engage-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    color: var(--color-ink);
  }
  .engage-body { font-size: 15px; color: var(--color-ink-secondary); line-height: 1.6; flex: 1; margin: 0; }

  .build-tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }
  .build-tier {
    padding: var(--space-4);
    border-right: 1px solid var(--color-border);
  }
  .build-tier:last-child { border-right: none; }
  .build-heading {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    color: var(--color-ink);
    margin-bottom: 12px;
  }
  .build-body { font-size: 14px; color: var(--color-ink-secondary); line-height: 1.6; margin: 0; }

  @media (max-width: 1279px) { .service-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 767px) {
    .hero { padding-top: 112px; }
    .hero-sub { font-size: 16px; }
    .service-grid { grid-template-columns: 1fr; }
    .engage-panels { grid-template-columns: 1fr; }
    .build-tiers { grid-template-columns: 1fr; }
    .build-tier { border-right: none; border-bottom: 1px solid var(--color-border); }
    .build-tier:last-child { border-bottom: none; }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import ClosingCTA from '../components/ClosingCTA.astro';
import Watermark from '../components/Watermark.astro';

const serviceCards = [
  { icon: 'receipt', heading: 'Finance & accounts', body: 'Invoice matching and approval workflows. Automated reconciliation. Payment follow-up and dunning. Month-end reporting without the scramble.' },
  { icon: 'clipboard-text', heading: 'Procurement & supplier management', body: 'Purchase order automation. Supplier onboarding and credential tracking. Contract expiry alerts. Spend visibility across fragmented systems.' },
  { icon: 'map-pin', heading: 'Field service & scheduling', body: 'Live job visibility and dispatch optimisation. Automated scheduling based on location, skills and availability. Real-time status updates without the phone calls.' },
  { icon: 'file-text', heading: 'Document processing', body: 'Automated document classification and data extraction. Contract review and flagging. Forms processing without manual rekeying.' },
  { icon: 'package', heading: 'Warehouse & inventory', body: 'Live inventory visibility across locations. Automated reorder triggers. Inbound and outbound reconciliation. Order status without chasing the warehouse.' },
  { icon: 'chart-line-up', heading: 'Sales operations', body: "Live product, pricing and inventory access for field reps. Order submission without back-office delays. Pipeline reporting without a spreadsheet." },
  { icon: 'headset', heading: 'Contact centre & service desk', body: 'Intelligent triage and routing. Automated responses to common requests. Knowledge assistants that give agents the right answer faster.' },
  { icon: 'chart-bar', heading: 'Reporting & business intelligence', body: 'Automated data pipelines from fragmented sources. Dashboards that update without someone building them each week. Alerts when something needs attention.' },
  { icon: 'wrench', heading: 'Asset operations', body: 'Failure prediction and maintenance optimisation. Work order scheduling automation. Language-first work execution via voice or text. Document intelligence for maintenance records and compliance.' },
];

const buildStaircase = [
  {
    num: '1',
    heading: 'Insights & intelligence',
    sublabel: 'Seeing ahead',
    body: 'Continuous analysis of operational data to surface patterns, predict outcomes and recommend action. Transforms the data your operations generate into a strategic asset — helping you see what\'s coming rather than react to what happened.',
  },
  {
    num: '2',
    heading: 'Task & workflow automation',
    sublabel: 'Clearing bottlenecks',
    body: 'Targeted automation of specific manual tasks, handoffs and data flows. Fast to deliver, immediate in impact. AI plays a role here too — extracting meaning from documents, routing requests intelligently, flagging exceptions before they become problems.',
  },
  {
    num: '3',
    heading: 'Process & integrated automation',
    sublabel: 'Working on autopilot',
    body: 'Connecting the dots across systems, teams and functions. Where task automation removes individual pain points, process automation eliminates the coordination overhead between them — integrating platforms, orchestrating multi-step workflows and giving management real visibility.',
  },
  {
    num: '4',
    heading: 'Agentic automation',
    sublabel: 'Reimagining operations',
    body: "Goal-oriented AI that monitors, decides and acts across complex workflows — with human oversight built in. Not science fiction. We're building and delivering agentic solutions now, across logistics, finance and field operations.",
  },
];

const techCards = [
  {
    icon: 'git-branch',
    label: 'Rule-based',
    heading: 'Task & rule automation',
    body: 'Handles repeatable logic — consistent, fast and predictable. The right foundation for any process that follows defined steps every time.',
  },
  {
    icon: 'chart-line',
    label: 'Decision support & insights',
    heading: 'Data analysis & recommendations',
    body: 'Analyses data from across your systems and surfaces clear recommendations for your team to act on. Turns information overload into decision clarity.',
  },
  {
    icon: 'sparkle',
    label: 'AI',
    heading: 'Agents and bots',
    body: 'Understands and generates language, documents, images, audio and other unstructured data. Handles the interactions and processing that used to require a person.',
  },
  {
    icon: 'robot',
    label: 'Autonomous',
    heading: 'Agentic systems',
    body: "Goal-oriented AI that monitors, decides and acts across complex workflows — with human oversight built in. Not science fiction. We're building and delivering this now.",
  },
];
---

<BaseLayout
  title="What we do — Sixense"
  description="We design and build automation and AI solutions across finance, field service, procurement, document processing and more. Fixed scope. Real outcomes."
>
  <!-- Hero -->
  <section class="hero section-dark" aria-labelledby="wwd-heading">
    <Watermark />
    <Watermark secondary={true} />
    <div class="container">
      <span class="section-label">What we do</span>
      <h1 id="wwd-heading" class="animate-in" style="max-width:720px;color:var(--color-paper)">
        Fix what's broken. Build what's missing.
      </h1>
      <p class="hero-sub animate-in" data-delay="80ms">
        Some of the businesses we work with have a specific problem they need fixed.
        Others can see an opportunity — a new capability, a better way of operating,
        something a competitor is doing that they can't yet — but have no way to build
        toward it. We do both.
      </p>
      <p class="hero-sub animate-in" data-delay="120ms" style="margin-top:1em">
        We design and build automation and AI solutions that eliminate operational drag
        and unlock capabilities that were previously out of reach. Each solution is built
        to stand alone and connect forward — so what we build today becomes the
        foundation for something more powerful tomorrow.
      </p>
    </div>
  </section>

  <!-- Outcomes We Enable -->
  <section class="section" aria-labelledby="service-heading">
    <Watermark variant="light" side="right" />
    <div class="container">
      <span class="section-label">Outcomes we enable</span>
      <h2 id="service-heading" class="animate-in">
        If your team is doing any of the following manually,<br />there's likely a better way.
      </h2>
      <div class="service-grid">
        {serviceCards.map((card, i) => (
          <div class="service-card animate-in" data-delay={`${(i % 3) * 80}ms`}>
            <div class="icon-circle icon-circle-sm">
              <i class={`ph ph-${card.icon}`} style="font-size:32px;color:#F4C542;" aria-hidden="true"></i>
            </div>
            <h3 class="svc-heading">{card.heading}</h3>
            <p class="svc-body">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How We Engage -->
  <section class="section section-secondary" aria-labelledby="engage-heading">
    <Watermark variant="light" side="left" />
    <div class="container">
      <span class="section-label">How we engage</span>
      <h2 id="engage-heading" class="animate-in" style="max-width:560px">
        Every engagement starts small and builds with purpose.
        Nothing is open-ended.
      </h2>
      <div class="engage-panels">
        <div class="engage-panel animate-in">
          <div class="icon-circle icon-circle-lg">
            <i class="ph ph-phone" style="font-size:48px;color:#F4C542;" aria-hidden="true"></i>
          </div>
          <span class="engage-tag">Free · 30 minutes</span>
          <h3 class="engage-heading">The Fit Call</h3>
          <p class="engage-body">
            An honest conversation to find out if there's a real problem and whether we're
            the right fit. No pitch. If there's something worth solving, we'll say so.
            If there isn't, we'll say that too.
          </p>
          <a href="/contact" class="btn btn-ghost">Book a Fit Call →</a>
        </div>
        <div class="engage-panel animate-in" data-delay="80ms">
          <div class="icon-circle icon-circle-lg">
            <i class="ph ph-magnifying-glass" style="font-size:48px;color:#F4C542;" aria-hidden="true"></i>
          </div>
          <span class="engage-tag">Fixed time · Fixed price</span>
          <h3 class="engage-heading">The Discovery Sprint</h3>
          <p class="engage-body">
            A structured working session requiring up to four hours of your time across five
            days. We map your most pressing processes, assess where automation can make the
            biggest difference and hand you a clear, plain-English report. Most clients find
            the clarity alone is worth the fee.
          </p>
          <a href="/how-we-work" class="btn btn-ghost">Learn more →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- How We Build — 2-col layout: left text, right staircase -->
  <section class="section" aria-labelledby="build-heading">
    <Watermark variant="light" side="right" />
    <div class="container build-layout">
      <div class="build-left animate-in">
        <span class="section-label">How we build</span>
        <h2 id="build-heading">From targeted enhancements to autonomous operations.</h2>
        <p class="build-intro">
          Think of automation as a ladder. Most businesses start with a single rung —
          a specific task, a recurring bottleneck, something that takes too long and
          costs too much. Each step up connects more of your operations, until the
          business is running on intelligence rather than effort.
        </p>
      </div>
      <div class="build-right animate-in" data-delay="80ms">
        {buildStaircase.map((tier, i) => (
          <div class={`tier-row tier-row-${i + 1}`}>
            <span class="tier-num" aria-hidden="true">{tier.num}</span>
            <div class="tier-content">
              <p class="tier-heading">{tier.heading}</p>
              <span class="tier-sublabel">{tier.sublabel}</span>
              <p class="tier-body">{tier.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Technology Choice — 4-col cards -->
  <section class="section section-secondary" aria-labelledby="tech-heading">
    <Watermark variant="light" side="left" />
    <div class="container">
      <div class="tech-header animate-in">
        <span class="section-label" style="justify-content:center">Technology choice</span>
        <h2 id="tech-heading" style="text-align:center">
          Fitting the right technical frameworks to your operations and environment is pivotal.
        </h2>
      </div>
      <div class="tech-cards">
        {techCards.map((card, i) => (
          <div class="tech-card animate-in" data-delay={`${i * 80}ms`}>
            <div class="icon-circle icon-circle-md" style="margin-bottom:20px">
              <i class={`ph ph-${card.icon}`} style="font-size:36px;color:#F4C542;" aria-hidden="true"></i>
            </div>
            <span class="tech-label">{card.label}</span>
            <h3 class="tech-card-heading">{card.heading}</h3>
            <p class="tech-card-body">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ClosingCTA
    heading="Not sure where you sit?"
    body="Start with the Fit Call. It's free and it'll be obvious pretty quickly."
    ctaLabel="Book a free Fit Call →"
    showContactLink={false}
  />
</BaseLayout>

<style>
  .hero { padding-top: 120px; padding-bottom: 80px; }
  .hero-sub {
    font-size: 18px;
    line-height: 1.7;
    color: rgba(245, 243, 238, 0.65);
    max-width: 620px;
    margin-top: var(--space-3);
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: var(--space-5);
  }
  .svc-heading {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    color: var(--color-ink);
  }
  .svc-body { font-size: 14px; color: var(--color-ink-secondary); line-height: 1.6; margin: 0; }

  .engage-panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-5);
  }
  .engage-panel {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .engage-tag {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 11px;
    color: var(--color-accent);
    background: var(--color-ink);
    border: 1px solid var(--color-ink);
    border-radius: var(--radius-sm);
    padding: 4px 10px;
    display: inline-block;
    width: fit-content;
  }
  .engage-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    color: var(--color-ink);
  }
  .engage-body { font-size: 15px; color: var(--color-ink-secondary); line-height: 1.6; flex: 1; margin: 0; }

  /* How We Build — 2-column layout */
  .build-layout {
    display: grid;
    grid-template-columns: 38% 58%;
    gap: 4%;
    align-items: start;
  }
  .build-intro {
    font-size: 16px;
    color: var(--color-ink-secondary);
    line-height: 1.75;
    margin-top: 20px;
  }

  /* Staircase */
  .build-right { display: flex; flex-direction: column; }
  .tier-row {
    background: var(--color-paper);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-md);
    padding: 18px 24px;
    margin-bottom: 12px;
    display: flex;
    align-items: flex-start;
    gap: 20px;
    cursor: default;
    transition: box-shadow 200ms ease;
  }
  .tier-row:hover { box-shadow: 0 4px 16px rgba(244, 197, 66, 0.12); }
  .tier-row-1 { margin-left: 0; }
  .tier-row-2 { margin-left: 32px; }
  .tier-row-3 { margin-left: 64px; }
  .tier-row-4 { margin-left: 96px; }
  .tier-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 48px;
    color: rgba(26, 26, 24, 0.15);
    line-height: 1;
    width: 48px;
    flex-shrink: 0;
    align-self: center;
  }
  .tier-content { flex: 1; }
  .tier-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    color: var(--color-ink);
    margin: 0;
  }
  .tier-sublabel {
    display: block;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13px;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-style: italic;
    margin-top: 4px;
  }
  .tier-body {
    font-size: 13px;
    color: var(--color-ink-secondary);
    line-height: 1.6;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 350ms ease, opacity 300ms ease, padding 300ms ease;
  }
  .tier-row:hover .tier-body {
    max-height: 200px;
    opacity: 1;
    padding-top: 10px;
  }

  /* Technology Choice */
  .tech-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .tech-header h2 { max-width: 680px; margin-inline: auto; }
  .tech-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .tech-card {
    background: var(--color-paper-secondary);
    border-radius: var(--radius-lg);
    padding: 28px 24px;
    border-top: 3px solid var(--color-accent);
    display: flex;
    flex-direction: column;
  }
  .tech-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13px;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }
  .tech-card-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    color: var(--color-ink);
    line-height: 1.3;
    margin-bottom: 12px;
  }
  .tech-card-body {
    font-size: 14px;
    color: var(--color-ink-secondary);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  @media (max-width: 1279px) {
    .service-grid { grid-template-columns: repeat(2, 1fr); }
    .tech-cards { grid-template-columns: repeat(2, 1fr); }
    .tier-row-2 { margin-left: 16px; }
    .tier-row-3 { margin-left: 32px; }
    .tier-row-4 { margin-left: 48px; }
  }
  @media (max-width: 767px) {
    .hero { padding-top: 112px; }
    .hero-sub { font-size: 16px; }
    .service-grid { grid-template-columns: 1fr; }
    .engage-panels { grid-template-columns: 1fr; }
    .build-layout { grid-template-columns: 1fr; }
    .tech-cards { grid-template-columns: 1fr; }
    .tier-row-1, .tier-row-2, .tier-row-3, .tier-row-4 { margin-left: 0; }
    /* On mobile show all body text — hover doesn't apply */
    .tier-body {
      max-height: none;
      opacity: 1;
      padding-top: 10px;
    }
  }
</style>

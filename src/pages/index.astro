---
import BaseLayout from '../layouts/BaseLayout.astro';
import ClosingCTA from '../components/ClosingCTA.astro';
import Watermark from '../components/Watermark.astro';
---

<BaseLayout
  title="Automation & AI for Australian operators — Sixense"
  description="We build automation and AI solutions that eliminate operational drag and unlock capabilities your business couldn't reach before. Mid-market specialists."
  isHome={true}
>
  <!-- Section 1: Hero -->
  <section class="hero section-dark" aria-labelledby="hero-heading">
    <Watermark />
    <div class="container hero-inner">
      <span class="section-label">Automation &amp; AI for operators</span>
      <h1 id="hero-heading" class="hero-heading animate-in">
        Still running on<br />manual and people?
      </h1>
      <p class="hero-sub animate-in" data-delay="80ms">
        Most business leaders we talk to have been living with the same operational
        frustrations for years — assuming it would be too expensive or too complex
        to fix. It's usually none of those things.
      </p>
      <div class="hero-actions animate-in" data-delay="160ms">
        <a href="/contact" class="btn btn-primary">Book a free Fit Call — no pitch, 30 minutes</a>
        <p class="hero-sub-note">Free 30-minute conversation. No pitch.</p>
      </div>
    </div>
  </section>

  <!-- Section 2: The Problem -->
  <section class="section" aria-labelledby="problem-heading">
    <div class="container two-col two-col-40-55">
      <div>
        <span class="section-label">The problem</span>
        <h2 id="problem-heading" class="animate-in">
          Growth adds people.<br />It doesn't have to.
        </h2>
      </div>
      <div class="animate-in" data-delay="80ms">
        <p class="body-large" style="color:var(--color-ink-secondary)">
          Many businesses scale by adding headcount to absorb the workload — more staff
          handling more volume, doing things the way they've always been done. It works,
          until it doesn't. The cracks show up as errors, delays, key person dependencies
          and a growing sense that the business is harder to run than it should be.
        </p>
        <p class="body-large" style="color:var(--color-ink-secondary);margin-top:1em">
          Automation and AI don't replace your people. They free them up to do the work
          that actually needs them.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 3: Who We Work With -->
  <section class="section section-secondary" aria-labelledby="who-heading">
    <div class="container">
      <span class="section-label">Who we work with</span>
      <h2 id="who-heading" class="animate-in" style="max-width:700px">
        We work with operators, not IT departments.
      </h2>
      <p class="animate-in body-large" data-delay="80ms" style="color:var(--color-ink-secondary);max-width:640px;margin-top:var(--space-3)">
        Our clients are GMs, COOs, operations managers and business owners in
        asset-heavy, service-intensive and operationally complex businesses.
        They know their industry deeply. They don't need to know anything about
        technology — that's our job.
      </p>

      <div class="who-icons animate-in" data-delay="160ms">
        <div class="who-item">
          <div class="icon-circle icon-circle-md">
            <ph-icon name="truck" size="40" color="#00C2FF"></ph-icon>
          </div>
          <p class="who-label">Asset-heavy businesses</p>
          <p class="who-desc">Transport, utilities, logistics, infrastructure</p>
        </div>
        <div class="who-item">
          <div class="icon-circle icon-circle-md">
            <ph-icon name="wrench" size="40" color="#00C2FF"></ph-icon>
          </div>
          <p class="who-label">Service-intensive operations</p>
          <p class="who-desc">Healthcare, field service, maintenance</p>
        </div>
        <div class="who-item">
          <div class="icon-circle icon-circle-md">
            <ph-icon name="tree-structure" size="40" color="#00C2FF"></ph-icon>
          </div>
          <p class="who-label">Operationally complex</p>
          <p class="who-desc">Multi-site, multi-system, high-volume</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: Proof Signal -->
  <section class="section" aria-labelledby="proof-heading">
    <div class="container two-col two-col-40-55">
      <div>
        <span class="section-label">Proven outcomes</span>
        <h2 id="proof-heading" class="animate-in">
          We've done<br />this before.
        </h2>
        <p class="animate-in" data-delay="80ms" style="color:var(--color-ink-secondary);margin-top:var(--space-2);font-size:16px;line-height:1.7">
          From a national transport operator with no live fleet visibility, to a utility
          managing thousands of contractors on high-voltage assets, to a logistics
          business drowning in manual invoicing — we've built working solutions across
          some of Australia's most operationally demanding businesses.
        </p>
        <a href="/our-outcomes" class="accent-link animate-in" data-delay="120ms" style="margin-top:var(--space-3)">
          See our outcomes →
        </a>
      </div>

      <div class="proof-blocks animate-in" data-delay="80ms">
        <div class="proof-block">
          <ph-icon name="trophy" size="24" color="#00C2FF" style="flex-shrink:0;margin-top:2px"></ph-icon>
          <div class="proof-block-text">
            <p class="proof-headline">Industry award winner</p>
            <p class="proof-detail">Contractor authorisations platform — major Australian utility</p>
          </div>
        </div>
        <div class="proof-block">
          <ph-icon name="timer" size="24" color="#00C2FF" style="flex-shrink:0;margin-top:2px"></ph-icon>
          <div class="proof-block-text">
            <p class="proof-headline">Working prototype in 3 months</p>
            <p class="proof-detail">Energy dispatch optimisation — after 3 years of stalled attempts</p>
          </div>
        </div>
        <div class="proof-block">
          <ph-icon name="eye" size="24" color="#00C2FF" style="flex-shrink:0;margin-top:2px"></ph-icon>
          <div class="proof-block-text">
            <p class="proof-headline">Live fleet visibility in 30 days</p>
            <p class="proof-detail">National passenger transport operator, 500+ vehicles</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ClosingCTA />
</BaseLayout>

<style>
  .hero {
    padding-top: 160px;
    padding-bottom: 120px;
  }
  .hero-inner {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .hero-heading { color: var(--color-paper); margin-bottom: var(--space-3); }
  .hero-sub {
    font-size: 20px;
    line-height: 1.7;
    color: rgba(245, 243, 238, 0.65);
    max-width: 520px;
    margin-top: var(--space-3);
  }
  .hero-actions {
    margin-top: var(--space-5);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  .hero-sub-note {
    font-size: 13px;
    color: rgba(245, 243, 238, 0.4);
    margin: 0;
  }

  /* Who icons */
  .who-icons {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
    margin-top: var(--space-6);
    max-width: 800px;
  }
  .who-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .who-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    color: var(--color-ink);
    margin: 0;
  }
  .who-desc { font-size: 13px; color: var(--color-ink-secondary); margin: 0; }

  @media (max-width: 767px) {
    .hero { padding-top: 112px; padding-bottom: 80px; }
    .hero-sub { font-size: 16px; }
    .who-icons { grid-template-columns: 1fr; }
  }
</style>
